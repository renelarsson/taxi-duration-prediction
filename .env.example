
# =============================
# .env.example - User Settings
# =============================
# Copy this file to .env and update the values below with your own secrets and configuration.
# DO NOT use example passwords, account IDs, or bucket names in production!

# AWS Configuration
AWS_REGION=eu-north-1           # <-- Change to your AWS region
AWS_ACCOUNT_ID=123456789012     # <-- Change to your AWS account ID

# MLflow Configuration  
MLFLOW_TRACKING_URI=http://localhost:5000         # <-- Change if using a remote MLflow server
MLFLOW_S3_ENDPOINT_URL=https://s3.eu-north-1.amazonaws.com  # <-- Change if your S3 endpoint/region is different

# Database Configuration (for Grafana/monitoring)
DB_HOST=localhost               # <-- Change if your database is remote
DB_USER=postgres                # <-- Change to your database user
DB_PASSWORD=example             # <-- Change to a secure password!
DB_NAME=test                    # <-- Change to your database name

OUTPUT_STREAM_NAME=ride-predictions        # <-- Change to your output stream name
PREDICTIONS_STREAM_NAME=taxi-predictions   # <-- Change to your Kinesis stream name
MODEL_BUCKET=mlops-capstone-models         # <-- Change to your S3 bucket for models
INPUT_STREAM_NAME=ride-events              # <-- Change to your source stream name
