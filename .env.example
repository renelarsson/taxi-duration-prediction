# AWS Configuration
AWS_REGION=eu-north-1
AWS_ACCOUNT_ID=123456789012

# Terraform State
TF_STATE_BUCKET=tf-state-mlops-capstone

# MLflow Configuration  
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_S3_ENDPOINT_URL=https://s3.eu-north-1.amazonaws.com

# Database Configuration (for Grafana/monitoring)
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=example
DB_NAME=test

# Lambda Configuration (example values based on your terraform defaults)
PREDICTIONS_STREAM_NAME=taxi-predictions
MODEL_BUCKET=mlops-capstone-models
SOURCE_STREAM_NAME=taxi-trip-events
